# ── Backend (.env inside /backend) ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/khaubot
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8002,https://your-frontend.vercel.app

# ── Frontend (.env inside /frontend) ──────────────────────────────────────────
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,.vercel.app
CSRF_TRUSTED_ORIGINS=https://*.vercel.app
KHAUBOT_API_URL=http://localhost:8001   # FastAPI backend URL
